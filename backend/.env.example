# Port on which the Express server runs
PORT=3000

# MongoDB Connection String (e.g. mongodb+srv://... or mongodb://localhost:27017/myjournal)
MONGODB_URI=mongodb://localhost:27017/myjournal

# Environment mode (development or production)
NODE_ENV=development

# Allowed Frontend URL for CORS (e.g. http://localhost:5173 or your deployed frontend URL)
FRONTEND_URL=http://localhost:5173

# Optional: sameSite attribute for cookie. Default in prod is 'none' for cross-origin, or 'lax' / 'strict' if hosted on same domain.
# COOKIE_SAME_SITE=strict

# Optional: set to true to force secure cookies in non-production environments
# COOKIE_SECURE=false

# Optional: custom DNS servers for MongoDB connection if DNS resolution fails (e.g., 8.8.8.8,1.1.1.1)
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional: salt rounds for bcrypt password hashing (default is 10)
# BCRYPT_SALT_ROUNDS=10

# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
